{
  "version": 2,
  "builds": [
    {
      "src": "seda.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/seda.html",
      "dest": "/seda.html"
    },
    {
      "src": "/",
      "dest": "/seda.html"
    },
    {
      "src": "/(.*)",
      "dest": "/seda.html"
    }
  ]
}